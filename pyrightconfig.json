{
  "pythonVersion": "3.13",
  "venvPath": ".",
  "venv": ".venv",
  "include": ["tests", "tokenizer", "experiments"],
  "exclude": ["artifacts", "notebooks"],
  "typeCheckingMode": "strict",

  "reportUnknownMemberType": false,
